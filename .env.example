# ─── LLM ───────────────────────────────────────────────────────────────────────
# Provider: "ollama" (local) ou "groq" (nuvem via Groq API)
LLM_PROVIDER=ollama

# URL base — ignorada quando LLM_PROVIDER=groq (usa https://api.groq.com/openai)
LLM_BASE_URL=http://localhost:11434

# Modelo a usar:
#   Ollama local: llama3.1:8b
#   Groq:         llama-3.3-70b-versatile | llama3-8b-8192 | mixtral-8x7b-32768
LLM_MODEL=llama-3.3-70b-versatile

# Timeout em segundos para chamadas à LLM
LLM_TIMEOUT=60

# ─── Groq (necessário apenas quando LLM_PROVIDER=groq) ────────────────────────
# Obtenha sua chave em: https://console.groq.com/keys
GROQ_API_KEY=

# ─── Segurança ─────────────────────────────────────────────────────────────────
# Chave de API que os clientes devem enviar no header X-API-Key
API_KEY=API_KEY_TEST

# ─── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
