
#Provider: "ollama" (local) ou "groq" (Groq API)
LLM_PROVIDER=ollama

LLM_BASE_URL=http://localhost:11434

#Ollama local: llama3.1:8b
#Groq: llama-3.3-70b-versatile
LLM_MODEL=llama-3.3-70b-versatile

LLM_TIMEOUT=60

GROQ_API_KEY=

JWT_SECRET=temp
